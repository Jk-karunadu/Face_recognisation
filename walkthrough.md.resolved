└── src/
    ├── faces.py              # ★ Main recognition app (live + image modes)
    ├── faces-train.py        # ★ LBPH training pipeline
    ├── Face_detect.py        # Alt approach using `face_recognition` lib
    │
    ├── filter.py             # Live camera filter effects
    ├── glasses_and_stash.py  # AR: overlay glasses & mustache on faces
